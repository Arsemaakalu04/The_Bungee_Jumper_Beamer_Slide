% --- SLIDE 3: The Logic Loop (How it Works) ---
\section{Algorithmic Logic}
\begin{frame}{The Simulation Loop}
    \begin{enumerate}
        \item \textbf{Distance Check:} The code measures the distance from the anchor to the jumper.
        \item \textbf{Force Assessment:} 
        \begin{itemize}
            \item If distance $\leq 10m$: Only Gravity and Drag are applied.
            \item If distance $> 10m$: The Bungee Cord "kicks in" with a restoring force.
        \end{itemize}
        \item \textbf{Update Sequence:}
        \begin{itemize}
            \item New Acceleration = Net Force / Mass
            \item New Velocity = Old Velocity + (Acceleration $\times$ Time Step)
            \item New Position = Old Position + (New Velocity $\times$ Time Step)
        \end{itemize}
    \end{enumerate}
\end{frame}

